# ============================================================
# LeadKart Backend – env.example
# Copy this file → `.env`  (or `env`) and replace DEMO values
#   cp env.example .env
# ============================================================

# ---------- Server ----------
NODE_ENV=development
PORT=9898

# ---------- MongoDB ----------
MONGO_URI=mongodb+srv://demo_user:demo_password@cluster0.example.mongodb.net/LeadkartDemo
# Optional Mongo tuning
MONGO_APP_NAME=leadkart-api
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=1
MONGO_SERVER_SELECTION_TIMEOUT=90000
MONGO_SOCKET_TIMEOUT=60000
MONGO_WAIT_QUEUE_TIMEOUT=30000
MONGO_READ_PREFERENCE=primary
MONGO_RETRY_WRITES=true
MONGO_WRITE_CONCERN=majority
# MONGO_ADDITIONAL_DBS=[{"name":"analytics","uri":"mongodb+srv://..."}]

# ---------- Auth / JWT ----------
JWT_SECRET=demo_jwt_secret_change_me
JWT_SECRET_KEY=demo_jwt_secret_key_change_me
# Used to AES-encrypt WhatsApp Meta tokens in DB
ENCRYPTION_KEY=demo_encryption_key_change_me_32chars

# ---------- Email (Nodemailer) ----------
EMAIL_USER=demo@example.com
EMAIL_PASS=demo_email_app_password

# ---------- Object Storage (Spaces / S3-compatible) ----------
LINODE_OBJECT_STORAGE_REGION=sgp1
LINODE_OBJECT_STORAGE_ENDPOINT=sgp1.digitaloceanspaces.com
LINODE_OBJECT_BUCKET=demo-leadkart-bucket
LINODE_BUCKET_NAME=demo-leadkart-bucket
LINODE_OBJECT_ACCESS_KEY=DO00DEMOACCESSKEY0000
LINODE_OBJECT_SECRET_KEY=demo_object_storage_secret_key_replace_me

# ---------- OpenAI (AI template generate) ----------
OPENAI_API_KEY=sk-proj-demo-openai-api-key-replace-me

# ---------- Redis (BullMQ WhatsApp worker) ----------
# Either REDIS_URL  OR  HOST/PORT/PASSWORD
# REDIS_URL=redis://:demo_redis_password@127.0.0.1:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=demo_redis_password

# ---------- Razorpay (WhatsApp wallet) ----------
RAZORPAY_KEY_ID=rzp_test_demoKeyId000000
RAZORPAY_KEY_SECRET=demo_razorpay_key_secret_replace_me
# PAYMENTINSTRUMENT_TYPE=razorpay

# ---------- Meta / Facebook App (Ads + WhatsApp OAuth) ----------
clientId=100000000000005
clientSecret=demo_meta_client_secret_replace_me
businessId=100000000000003
adAccountId=act_100000000000004
assignUserId=100000000000001
systemUser=100000000000002
systemUserAccessToken=EAA_DEMO_SYSTEM_USER_ACCESS_TOKEN_REPLACE_ME
admin_access_token=EAA_DEMO_ADMIN_ACCESS_TOKEN_REPLACE_ME
meta_admin_id=100000000000000

# ---------- WhatsApp Cloud API / Webhooks ----------
WHATSAPP_WEBHOOK_VERIFY_TOKEN=demo_wa_webhook_verify_token
META_LEAD_WEBHOOK_VERIFY_TOKEN=demo_meta_lead_webhook_verify_token

# Meta Embedded Signup (OAuth Connect)
META_CONFIG_ID=DEMO_META_CONFIG_ID
META_OAUTH_REDIRECT_URI=http://localhost:9898/api/whatsapp/meta/callback

# Optional defaults if you wire platform-level WA (usually per-user in DB)
# WHATSAPP_ACCESS_TOKEN=EAA_DEMO_WHATSAPP_ACCESS_TOKEN_REPLACE_ME
# WHATSAPP_PHONE_NUMBER_ID=100000000000006
# WHATSAPP_BUSINESS_ACCOUNT_ID=100000000000007

# ---------- Firebase ----------
# Copy src/config/firebase.json.example → src/config/firebase.json
# and paste your Firebase service-account JSON (NOT committed).
